# Скопируйте в .netangels.env в корне проекта (файл в .gitignore).
# Ключ API: https://panel.netangels.ru/account/api/

NETANGELS_API_KEY=

# Зона без точки в конце (как в панели NetAngels)
NETANGELS_ZONE=truewebwork.ru

# Публичный IPv4 вашего VPS (Aeza) — на него выровняются все A для @ и www
TARGET_IPV4=138.124.90.218

# 1 — после обновления A удалить AAAA для корня и www (если IPv6 на VPS не настроен)
DELETE_AAAA=1
