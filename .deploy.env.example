# Локальные секреты для python deploy/full-deploy-vps.py (не коммитить).
# Скопируйте в .deploy.env и заполните:
#
# Чаще всего VPS принимает только ключ — укажите путь к приватному ключу:
# TRUWEB_VPS_SSH_KEY=C:\Users\Вы\.ssh\id_ed25519
#
# Если разрешён пароль:
# TRUWEB_VPS_SSH_PASSWORD=ваш_root_пароль
#
# TRUWEB_VPS_HOST=138.124.90.218
# TRUWEB_VPS_USER=root

TRUWEB_VPS_SSH_KEY=
TRUWEB_VPS_SSH_PASSWORD=
