# Локальные секреты для python deploy/full-deploy-vps.py (не коммитить).
# Скопируйте в .deploy.env и заполните:
#
# --- EU / основной сервер (Австрия и т.п.) — npm run deploy:vps или deploy:vps:eu ---
# TRUWEB_VPS_HOST=ваш_ip_европы
# TRUWEB_VPS_USER=root
# Чаще всего VPS принимает только ключ — укажите путь к приватному ключу:
# TRUWEB_VPS_SSH_KEY=C:\Users\Вы\.ssh\id_ed25519
#
# Если разрешён пароль:
# TRUWEB_VPS_SSH_PASSWORD=ваш_root_пароль
#
# --- RU / второй сервер (Москва) — npm run deploy:vps:ru или: python deploy/full-deploy-vps.py ru ---
# TRUWEB_VPS_HOST_RU=1.2.3.4
# TRUWEB_VPS_USER_RU=root
# TRUWEB_VPS_SSH_KEY_RU=C:\Users\Вы\.ssh\id_ed25519_moscow
# TRUWEB_VPS_SSH_PASSWORD_RU=
#
# Если TRUWEB_VPS_SSH_KEY_RU не задан — используется TRUWEB_VPS_SSH_KEY (тот же ключ на обоих).

TRUWEB_VPS_SSH_KEY=
TRUWEB_VPS_SSH_PASSWORD=

TRUWEB_VPS_HOST_RU=
TRUWEB_VPS_USER_RU=
TRUWEB_VPS_SSH_KEY_RU=
TRUWEB_VPS_SSH_PASSWORD_RU=
