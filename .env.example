# Личный кабинет клиента (чат): страница /account — вход по телефону+email из заказа и двум кодам (SMS + email).

# Публичный URL сайта (без слэша в конце). Нужен для return_url ЮKassa и ссылок в письмах.
# Локально: http://localhost:3000
# Продакшен: https://ваш-домен.ru
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Юридические данные на сайте (ЮKassa / совпадение с анкетой) ---
# ФИО как в ЕГРИП / анкете (обычно: Фамилия Имя Отчество)
NEXT_PUBLIC_LEGAL_FULL_NAME=Леонтьев Андрей Николаевич
NEXT_PUBLIC_LEGAL_INN=781441795345
# Для ИП — ОГРНИП из выписки (если пусто, на /requisites покажется подсказка)
NEXT_PUBLIC_LEGAL_OGRNIP=
# Полный юридический адрес из ЕГРИП (как в анкете платёжной системы)
NEXT_PUBLIC_LEGAL_ADDRESS=
# Контакты в футере и /privacy — совпадение с анкетой
NEXT_PUBLIC_CONTACT_EMAIL=info@truewebwork.ru
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=+1 682 293 6330
NEXT_PUBLIC_CONTACT_PHONE_TEL=+16822936330

# --- Оплата: только ЮKassa (корзина: POST /api/checkout/create-payment) ---
# Что взять в кабинете yookassa.ru: Идентификатор магазина (shopId) и Секретный ключ.
# Подробный чек-лист: docs/YOOKASSA.md
# НЕ коммить реальный .env в Git.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# 1 — пропуск шлюза и сразу редирект на /payment/return (для тестов; в dev включено и без этого)
# Действует и для общей кассы checkout.
PAYMENT_BYPASS=0
# Устаревший алиас (как PAYMENT_BYPASS)
YOOKASSA_BYPASS=0

# Comma-separated admin phones for purchase notifications.
# Example: 79216590009,79526657299
ORDER_NOTIFY_PHONES=79216590009,79526657299

# SMS provider for phone verification and admin 2FA.
# mock — коды только в логах сервера (удобно для разработки).
# В production для входа в админку укажите реальный провайдер (не mock).
SMS_PROVIDER=mock

# SMS.ru (если SMS_PROVIDER=smsru)
# SMS_RU_API_ID=
# SMS_RU_FROM= (необязательно; подпись/имя отправителя, если подключено в SMS.ru)
# Лимит звонков в сутки на один номер (по умолчанию 10)
# SMS_RU_CALLS_PER_DAY=10

# Telegram contact phone in international format for return-page button.
# Example: 15551234567 (without +)
NEXT_PUBLIC_TELEGRAM_MANAGER_PHONE=16822936330

# Admin panel bootstrap credentials.
ADMIN_EMAIL=admin@truewebwork.ru
ADMIN_PASSWORD=change_me_strong_password
# Телефон для SMS-кода входа в админку (79XXXXXXXXX, без +). Если пусто — берётся первый номер из ORDER_NOTIFY_PHONES.
ADMIN_PHONE=

# Только для production при SMS_PROVIDER=mock: 1 — разрешить 2FA, SMS-код в логах PM2 (pm2 logs business-card-site).
# ADMIN_2FA_ALLOW_SMS_MOCK=1
# Если SMTP не настроен: 1 — код из «письма» тоже в логах PM2 (вместе с SMS-кодом).
# ADMIN_2FA_ALLOW_EMAIL_MOCK=1

# Фиксированный OTP 111111 для админки, /account и корзины: lib/fixed-otp.ts → USE_FIXED_OTP_EVERYWHERE (перед продом выключить).

# 1 — не слать письма/SMS при входе в админку (если выключен фиксированный OTP в lib/fixed-otp.ts).
# ADMIN_2FA_SKIP_DELIVERY=1

# SMTP settings for real email sending from admin panel.
# If not filled, email sending works in mock mode (server logs only).
# В production для входа в админку 2FA обязателен: нужен реальный SMTP (код на email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Пример для Яндекс.Почты (на VPS часто стабильнее порт 465):
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=ваш_ящик@yandex.ru
# SMTP_PASS=пароль_приложения
# SMTP_FROM= (можно не указывать — возьмётся SMTP_USER)
# При таймаутах на 587: попробуйте 465 или SMTP_FORCE_IPV4=1 в .env на сервере.
# SMTP_SECURE=1 — принудительно SSL. SMTP_SEND_ATTEMPTS=3 — число повторов при сбоях сети.

# DeepSeek AI чат для страницы /ai-chat
# Получите ключ в кабинете DeepSeek и вставьте сюда.
DEEPSEEK_API_KEY=
